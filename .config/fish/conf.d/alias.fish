# General Alias
alias repos='cd ~/repos'
alias ll='ls -lha'
alias history='history --show-time="%a %H %M %S - " --reverse'

alias jf='jfrog'
alias tf='terraform'
alias h='helm'
alias lg='lazygit'

# Kubernetes Alias
alias kc=kubectl
alias kcgc='kubectl config get-contexts'

# Kubernetes Fuzzy Search Functions
alias kcx='kcx-fzf'      # Fuzzy switch context
alias kcn='kcn-fzf'      # Fuzzy switch namespace
alias kp='kgp-fzf'       # Fuzzy select pods
alias kd='kgd-fzf'       # Fuzzy select deployments
alias ks='kgs-fzf'       # Fuzzy select services

# Git & Yadm Alias
alias gst='git status'
alias y='yadm'
alias yst='yadm status'
alias ydiff='yadm diff'

## Azure Cloud
alias azi='az interactive'

## Google Cloud
alias gc='gcloud'
alias dc='docker-compose'


