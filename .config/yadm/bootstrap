#!/bin/bash

# Main bootstrap script for YADM
set -eu

# --- Logging setup ---
LOG_FILE="$HOME/.yadm_bootstrap.log"
# Clear old log and start new one, redirecting all output to both file and terminal
exec > >(tee "$LOG_FILE") 2>&1

echo "Logging to $LOG_FILE"

# Directory to look for bootstrap executables in
BOOTSTRAP_D="${BASH_SOURCE[0]}.d"

# --- OS Detection ---
SYSTEM_TYPE=$(uname -s)
OS_ID=""
IS_WSL2=false

if [ "$SYSTEM_TYPE" = "Linux" ]; then
    if grep -qi microsoft /proc/version; then
        IS_WSL2=true
    fi
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        OS_ID=$ID
    fi
fi

echo "--- YADM Bootstrap ---"
echo "Detected OS: $SYSTEM_TYPE"
[ -n "$OS_ID" ] && echo "Distro: $OS_ID"
[ "$IS_WSL2" = true ] && echo "Environment: WSL2"
echo "----------------------"

# --- Execute resolved bootstrap scripts (no ## in name) ---
# yadm automatically resolves filenames like 'script##os.Darwin' 
# to 'script' during checkout.
if [[ -d "$BOOTSTRAP_D" ]]; then
    # Use find to locate all files and check if they are executable in the loop
    find "$BOOTSTRAP_D" -type f | sort | while IFS= read -r bootstrap; do
        if [[ -x "$bootstrap" && ! "$bootstrap" =~ "##" && ! "$bootstrap" =~ "~$" ]]; then
            echo ">> Executing $bootstrap..."
            if ! "$bootstrap"; then
                echo "!! Error: bootstrap '$bootstrap' failed" >&2
                exit 1
            fi
        fi
    done
fi

# --- Manual OS-Specific fallback logic if needed ---

# macOS specific (if not already handled in bootstrap.d scripts)
if [ "$SYSTEM_TYPE" = "Darwin" ]; then
  # install homebrew if it's missing
  if ! command -v brew >/dev/null 2>&1; then
    echo "Installing homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  fi
fi

# --- Post-Bootstrap Summary ---
echo "Bootstrap process completed."
