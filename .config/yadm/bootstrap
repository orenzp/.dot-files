#!/bin/bash

# Main bootstrap script for YADM
set -eu

# --- Logging setup ---
LOG_FILE="$HOME/.yadm_bootstrap.log"
# Clear old log and start new one, redirecting all output to both file and terminal
exec > >(tee "$LOG_FILE") 2>&1

echo "Logging to $LOG_FILE"

# Directory to look for bootstrap executables in
BOOTSTRAP_D="${BASH_SOURCE[0]}.d"

# --- OS Detection ---
SYSTEM_TYPE=$(uname -s)
OS_ID=""
IS_WSL2=false

if [ "$SYSTEM_TYPE" = "Linux" ]; then
    if grep -qi microsoft /proc/version; then
        IS_WSL2=true
    fi
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        OS_ID=$ID
    fi
fi

echo "--- YADM Bootstrap ---"
echo "Detected OS: $SYSTEM_TYPE"
[ -n "$OS_ID" ] && echo "Distro: $OS_ID"
[ "$IS_WSL2" = true ] && echo "Environment: WSL2"
echo "----------------------"

# --- Execute bootstrap scripts ---
if [[ -d "$BOOTSTRAP_D" ]]; then
    # Get a list of base script names (without suffixes)
    mapfile -t base_scripts < <(find "$BOOTSTRAP_D" -type f | sed -E 's/##.*$//' | sort -u)

    for base in "${base_scripts[@]}"; do
        # Use yadm's own naming convention to find the best match for this OS
        # Check for: base##os.Linux (or Darwin), then base##os, then base
        script=""
        if [[ -f "${base}##os.${SYSTEM_TYPE}" ]]; then
            script="${base}##os.${SYSTEM_TYPE}"
        elif [[ -f "${base}##os.${OS_ID}" ]]; then
            script="${base}##os.${OS_ID}"
        elif [[ -f "${base}##os" ]]; then
            script="${base}##os"
        elif [[ -f "${base}" && ! "${base}" =~ "##" ]]; then
            script="${base}"
        fi

        if [[ -n "$script" && -x "$script" ]]; then
            echo ">> Executing $script..."
            if ! "$script"; then
                echo "!! Error: bootstrap '$script' failed" >&2
                exit 1
            fi
        fi
    done
fi

# --- Manual OS-Specific fallback logic if needed ---

# macOS specific (if not already handled in bootstrap.d scripts)
if [ "$SYSTEM_TYPE" = "Darwin" ]; then
  # install homebrew if it's missing
  if ! command -v brew >/dev/null 2>&1; then
    echo "Installing homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  fi
fi

# --- Post-Bootstrap Summary ---
echo "Bootstrap process completed."
